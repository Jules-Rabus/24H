#!/bin/sh
# Pre-commit hook — mirrors Frontend CI and Backend CI static checks.

STAGED=$(git diff --cached --name-only --diff-filter=ACM)

STAGED_PWA=$(echo "$STAGED" | grep "^pwa/" || true)
STAGED_API=$(echo "$STAGED" | grep "^api/" || true)

# ── Frontend (pwa/) — runs locally ──────────────────────────────────────────
if [ -n "$STAGED_PWA" ]; then
  echo "[pre-commit] pwa: lint..."
  (cd pwa && npm run lint) || exit 1

  echo "[pre-commit] pwa: format:check..."
  (cd pwa && npm run format:check) || exit 1

  echo "[pre-commit] pwa: type:check..."
  (cd pwa && npm run type:check) || exit 1

  echo "[pre-commit] pwa: test..."
  (cd pwa && npm run test) || exit 1
fi

# ── Backend (api/) — runs in Docker ─────────────────────────────────────────
if [ -n "$STAGED_API" ]; then
  if command -v docker >/dev/null 2>&1 && docker compose ps --status running php 2>/dev/null | grep -q php; then
    echo "[pre-commit] api: php-cs-fixer..."
    docker compose exec -T php vendor/bin/php-cs-fixer check --config=.php-cs-fixer.dist.php || exit 1

    echo "[pre-commit] api: phpstan..."
    docker compose exec -T php vendor/bin/phpstan analyse --configuration=phpstan.dist.neon --memory-limit=512M || exit 1

    echo "[pre-commit] api: phpunit..."
    docker compose exec -T php bin/phpunit --no-coverage || exit 1
  else
    echo "[pre-commit] php container not running — skipping backend checks"
    echo "  Start with: docker compose up php -d"
  fi
fi