parameters:
    level: 6
    paths:
        - src
    ignoreErrors:
        -
            identifier: shipmonk.deadMethod
            path: src/Entity/*
        -
            identifier: shipmonk.deadMethod
            path: src/Controller/*
        -
            identifier: doctrine.associationType
            path: src/Entity/Participation.php
        # DTO/Resource properties and methods are used by the Symfony Serializer/Security at runtime
        -
            identifier: shipmonk.deadProperty.neverRead
            path: src/ApiResource/*
        -
            identifier: shipmonk.deadProperty.neverWritten
            path: src/ApiResource/*
        -
            identifier: shipmonk.deadProperty.neverRead
            path: src/Dto/*
        -
            identifier: shipmonk.deadProperty.neverWritten
            path: src/Dto/*
        # instanceof check on PHPDoc union type — false positive
        -
            identifier: instanceof.alwaysFalse
            path: src/State/UserProcessor.php
    symfony:
        containerXmlPath: var/cache/dev/App_KernelDevDebugContainer.xml
    shipmonkDeadCode:
        detect:
            deadMethods: true
            deadConstants: true
            deadEnumCases: false
        usageProviders:
            symfony:
                enabled: true
                configDir: %currentWorkingDirectory%/config
            doctrine:
                enabled: true
            twig:
                enabled: true
        usageExcluders:
            tests:
                enabled: true
                devPaths:
                    - %currentWorkingDirectory%/tests
