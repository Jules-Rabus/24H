{
  "name": "pwa",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:mock": "cross-env NEXT_PUBLIC_API_MOCK=1 next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "type:check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate-api": "OPENAPI_INPUT=http://php/docs.jsonopenapi openapi-ts",
    "prepare": "true"
  },
  "dependencies": {
    "@bwip-js/browser": "^4.6.0",
    "@chakra-ui/react": "^3.34.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/poppins": "^5.2.5",
    "@playwright/test": "^1.58.2",
    "@react-pdf/renderer": "^4.3.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.1.5",
    "@tanstack/query-core": "^5.95.2",
    "@tanstack/react-form": "^1.28.5",
    "@tanstack/react-query": "^5.95.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@yudiel/react-qr-scanner": "^2.3.1",
    "axios": "^1.14.0",
    "embla-carousel": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.38.0",
    "jsdom": "^29.0.1",
    "jszip": "^3.10.1",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^1.7.0",
    "msw": "^2.12.14",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.6.0",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.0.12",
    "vitest": "^4.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.27.1",
    "@eslint/eslintrc": "^3.3.1",
    "@hey-api/client-axios": "^0.9.1",
    "@hey-api/openapi-ts": "^0.94.5",
    "@popperjs/core": "^2.11.8",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/file-saver": "^2.0.7",
    "@types/lodash.isplainobject": "^4.0.9",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.3",
    "@vitest/coverage-v8": "^4.1.1",
    "cross-env": "^10.1.0",
    "daisyui": "^5.0.35",
    "eslint": "^9.26.0",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "@babel/core": "^7.19.0",
    "@popperjs/core": "^2.11.6"
  },
  "packageManager": "npm@10.9.0",
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint"
    ],
    "*.{js,mjs,json,css,md}": [
      "prettier --write"
    ]
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
